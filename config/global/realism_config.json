        "enabled": true,
        "config_file": "correlation_config.json"
      },
      "dynamic_capacity": {
        "enabled": true
      },
      "incidents": {
        "enabled": true
      },
      "entity_skew": {
        "enabled": true
      },
      "metadata_quality": {
        "enabled": true
      },
