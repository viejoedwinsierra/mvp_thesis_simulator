{
  "config_metadata": {
    "config_name": "error_config",
    "version": "2.0",
    "owner": "base_error_probability_error_taxonomy_and_error_limits",
    "description": "Unica fuente para probabilidad base, multiplicadores tecnicos, severidad y familias de error."
  },
  "errors": {
    "enabled": true,
    "base_error_probability": 0.02,
    "probability_controls": {
      "min_error_probability": 0.0,
      "max_error_probability": 0.95,
      "max_after_technical_multipliers": 0.45,
      "max_after_temporal_multipliers": 0.6,
      "max_after_correlations": 0.8
    },
    "multipliers": {
      "large_file": {
        "enabled": true,
        "threshold_mb": 100,
        "multiplier": 2.5
      },
      "low_speed": {
        "enabled": true,
        "threshold_mbps": 5,
        "multiplier": 3.0
      },
      "long_transfer": {
        "enabled": true,
        "threshold_sec": 120,
        "multiplier": 2.0
      },
      "archive_tier": {
        "enabled": true,
        "multiplier": 1.4
      },
      "movement_storage": {
        "enabled": true,
        "multiplier": 1.3
      }
    },
    "severity_rules": {
      "low": {
        "min_error_probability": 0.0,
        "max_error_probability": 0.05
      },
      "medium": {
        "min_error_probability": 0.05,
        "max_error_probability": 0.15
      },
      "high": {
        "min_error_probability": 0.15,
        "max_error_probability": 0.35
      },
      "critical": {
        "min_error_probability": 0.35,
        "max_error_probability": 1.0
      }
    },
    "output_columns": {
      "has_error": true,
      "error_probability": true,
      "error_family": true,
      "error_type": true,
      "severity": true
    },
    "error_families": [
      {
        "name": "DUPLICITY_ERRORS",
        "enabled": true,
        "weight_within_global_error": 0.4,
        "subtypes": [
          {
            "name": "DUP_SAME_CONTENT_DIFFERENT_NAME",
            "weight_within_family": 0.4
          },
          {
            "name": "DUP_SAME_CONTENT_DIFFERENT_ROUTE",
            "weight_within_family": 0.35
          },
          {
            "name": "DUP_SAME_CONTENT_DIFFERENT_NAME_AND_ROUTE",
            "weight_within_family": 0.25
          }
        ]
      },
      {
        "name": "ORPHAN_ERRORS",
        "enabled": true,
        "weight_within_global_error": 0.3,
        "subtypes": [
          {
            "name": "JSON_WITHOUT_PDF",
            "weight_within_family": 0.6
          },
          {
            "name": "PDF_WITHOUT_JSON",
            "weight_within_family": 0.4
          }
        ]
      },
      {
        "name": "NULL_ERRORS",
        "enabled": true,
        "weight_within_global_error": 0.15,
        "subtypes": [
          {
            "name": "NULL_JSON",
            "weight_within_family": 1.0
          }
        ]
      },
      {
        "name": "BLOB_STORAGE_ERRORS",
        "enabled": true,
        "weight_within_global_error": 0.15,
        "subtypes": [
          {
            "name": "BLOB_TIMEOUT",
            "weight_within_family": 1.0
          }
        ],
        "conditions": {
          "requires": [
            "large_file",
            "low_speed"
          ]
        }
      }
    ],
    "execution_order": [
      "base_error_probability",
      "time_slot_error_multiplier",
      "technical_multipliers",
      "noise_effects",
      "realism_effects",
      "correlation_effects",
      "final_clamp"
    ]
  }
}