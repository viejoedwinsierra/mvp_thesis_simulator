{
  "simulation": {
    "max_valid_files_per_day": 10000,
    "output_dir": "./output",
    "seed": 4
  },

  "daily_charge": {
    "monday": "medium",
    "tuesday": "high",
    "wednesday": "medium",
    "thursday": "high",
    "friday": "medium",
    "saturday": "medium",
    "sunday": "low"
  },

  "base_load_profiles": {
    "low": {
      "min": 0.10,
      "max": 0.25
    },
    "medium": {
      "min": 0.26,
      "max": 0.55
    },
    "high": {
      "min": 0.56,
      "max": 0.99
    }
  },
  
  "arrival_process": {
    "strategy": "poisson",
    "hourly_noise": 0.12
  },

  "capacity": {
    "enabled": true,
    "files_per_hour": 900,
    "duration_penalty_factor": 0.55,
    "error_penalty_factor": 0.35
  },

  "outliers": {
    "enabled": true,
    "probability": 0.02,
    "size_multiplier_min": 2,
    "size_multiplier_max": 7
  },

  "file_types": {
    "distribution": {
      "json": 0.25,
      "jpg": 0.30,
      "pdf": 0.25,
      "mp4": 0.20
    },
    "size_distribution_mb": {
      "json": {
        "distribution": "lognormal",
        "mean": 0.1,
        "sigma": 0.8,
        "min": 0.001,
        "max": 0.5
      },
      "jpg": {
        "distribution": "lognormal",
        "mean": 1.5,
        "sigma": 0.7,
        "min": 0.1,
        "max": 8
      },
      "pdf": {
        "distribution": "lognormal",
        "mean": 2.5,
        "sigma": 0.9,
        "min": 0.05,
        "max": 20
      },
      "mp4": {
        "distribution": "lognormal",
        "mean": 4.8,
        "sigma": 0.85,
        "min": 5,
        "max": 550
      }
    }
  },

  "transfer": {
    "speed_mbps": {
      "distribution": "lognormal",
      "mean": 3.2,
      "sigma": 0.65,
      "min": 1,
      "max": 300
    },
    "duration_strategy": "size_divided_by_speed"
  }
}