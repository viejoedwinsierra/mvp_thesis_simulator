{
  "simulation": {
    "max_valid_files_per_day": 900,
    "output_dir": "./output",
    "seed": 9020
  },
  "daily_charge": {
    "monday": "high",
    "tuesday": "high",
    "wednesday": "high",
    "thursday": "high",
    "friday": "high",
    "saturday": "high",
    "sunday": "medium"
  },
  "base_load_profiles": {
    "low": {
      "min": 0.12,
      "max": 0.22
    },
    "medium": {
      "min": 0.3,
      "max": 0.5
    },
    "high": {
      "min": 0.55,
      "max": 0.8
    }
  },
  "arrival_process": {
    "strategy": "poisson",
    "hourly_noise": 0.14
  },
  "capacity": {
    "enabled": true,
    "files_per_hour": 10,
    "duration_penalty_factor": 0.75,
    "error_penalty_factor": 0.45
  },
  "outliers": {
    "enabled": true,
    "probability": 0.1,
    "size_multiplier_min": 2.5,
    "size_multiplier_max": 12,
    "max_size_mb": 1500
  },
  "file_types": {
    "distribution": {
      "json": 0.15,
      "jpg": 0.2,
      "pdf": 0.25,
      "mp4": 0.4
    },
    "size_distribution_mb": {
      "json": {
        "distribution": "lognormal",
        "mean": 0.05,
        "sigma": 0.55,
        "min": 0.001,
        "max": 0.5
      },
      "jpg": {
        "distribution": "lognormal",
        "mean": 1.25,
        "sigma": 0.55,
        "min": 0.1,
        "max": 8
      },
      "pdf": {
        "distribution": "lognormal",
        "mean": 2.1,
        "sigma": 0.65,
        "min": 0.05,
        "max": 20
      },
      "mp4": {
        "distribution": "lognormal",
        "mean": 5.45,
        "sigma": 0.85,
        "min": 10,
        "max": 800
      }
    }
  },
  "transfer": {
    "speed_mbps": {
      "distribution": "lognormal",
      "mean": 3.0,
      "sigma": 0.85,
      "min": 1,
      "max": 150
    },
    "duration_strategy": "size_divided_by_speed"
  },
  "scenario": {
    "name": "20_caos_controlado",
    "description": "Escenario extremo controlado con alta carga, baja capacidad, red variable y outliers."
  }
}