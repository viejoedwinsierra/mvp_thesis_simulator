{
  "errors": {
    "enabled": true,

    "base_error_probability": 0.020,

    "probability_controls": {
      "min_error_probability": 0.000,
      "max_error_probability": 0.950,

      "max_after_technical_multipliers": 0.45,
      "max_after_temporal_multipliers": 0.60,
      "max_after_correlations": 0.80
    },

    "multipliers": {

      "large_file": {
        "enabled": true,
        "threshold_mb": 100,
        "multiplier": 2.50
      },

      "low_speed": {
        "enabled": true,
        "threshold_mbps": 5,
        "multiplier": 3.00
      },

      "long_transfer": {
        "enabled": true,
        "threshold_sec": 120,
        "multiplier": 2.00
      },

      "archive_tier": {
        "enabled": true,
        "multiplier": 1.40
      },

      "movement_storage": {
        "enabled": true,
        "multiplier": 1.30
      }
    },

    "severity_rules": {

      "low": {
        "min_error_probability": 0.000,
        "max_error_probability": 0.050
      },

      "medium": {
        "min_error_probability": 0.050,
        "max_error_probability": 0.150
      },

      "high": {
        "min_error_probability": 0.150,
        "max_error_probability": 0.350
      },

      "critical": {
        "min_error_probability": 0.350,
        "max_error_probability": 1.000
      }
    },

    "output_columns": {
      "has_error": true,
      "error_probability": true,
      "error_family": true,
      "error_type": true,
      "severity": true
    },

    "error_families": [

      {
        "name": "DUPLICITY_ERRORS",

        "enabled": true,

        "weight_within_global_error": 0.40,

        "subtypes": [

          {
            "name": "DUP_SAME_CONTENT_DIFFERENT_NAME",
            "weight_within_family": 0.40
          },

          {
            "name": "DUP_SAME_CONTENT_DIFFERENT_ROUTE",
            "weight_within_family": 0.35
          },

          {
            "name": "DUP_SAME_CONTENT_DIFFERENT_NAME_AND_ROUTE",
            "weight_within_family": 0.25
          }
        ]
      },

      {
        "name": "ORPHAN_ERRORS",

        "enabled": true,

        "weight_within_global_error": 0.30,

        "subtypes": [

          {
            "name": "JSON_WITHOUT_PDF",
            "weight_within_family": 0.60
          },

          {
            "name": "PDF_WITHOUT_JSON",
            "weight_within_family": 0.40
          }
        ]
      },

      {
        "name": "NULL_ERRORS",

        "enabled": true,

        "weight_within_global_error": 0.15,

        "subtypes": [

          {
            "name": "NULL_JSON",
            "weight_within_family": 1.00
          }
        ]
      },

      {
        "name": "BLOB_STORAGE_ERRORS",

        "enabled": true,

        "weight_within_global_error": 0.15,

        "subtypes": [

          {
            "name": "BLOB_TIMEOUT",
            "weight_within_family": 1.00
          }
        ],

        "conditions": {
          "requires": [
            "large_file",
            "low_speed"
          ]
        }
      }
    ]
  }
}